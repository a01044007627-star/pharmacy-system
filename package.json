{
  "name": "pharmacy-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsc --noEmit && next build --turbopack",
    "start": "next start",
    "lint": "eslint src scripts",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs --passWithNoTests",
    "test:watch": "jest --config jest.config.cjs --watch --passWithNoTests",
    "db:build": "node scripts/build-supabase-deploy.mjs",
    "audit:project": "node scripts/audit-project.mjs",
    "verify": "tsc --noEmit && jest --config jest.config.cjs --runInBand --passWithNoTests && eslint src scripts --quiet && node scripts/audit-project.mjs && node scripts/audit-operational-loading.mjs && node scripts/audit-domain-architecture.mjs && node scripts/audit-p0-p1-integrity.mjs",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['.next','coverage']) fs.rmSync(p,{recursive:true,force:true})\"",
    "ci:verify": "corepack pnpm install --frozen-lockfile && corepack pnpm run verify && corepack pnpm run build",
    "lint:ci": "eslint src scripts --quiet",
    "test:ci": "jest --config jest.config.cjs --runInBand --passWithNoTests",
    "audit:operational-loading": "node scripts/audit-operational-loading.mjs",
    "audit:domain": "node scripts/audit-domain-architecture.mjs",
    "audit:p0-p1": "node scripts/audit-p0-p1-integrity.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@serwist/sw": "^9.5.11",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@uploadthing/react": "^7.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "exceljs": "4.4.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.18.0",
    "motion": "^11.18.2",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "react-to-print": "^3.3.0",
    "recharts": "^2.15.4",
    "serwist": "^9.5.11",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "20.x",
    "pnpm": ">=10.12.1 <11"
  },
  "browserslist": [
    "Chrome >= 109",
    "Edge >= 109",
    "Firefox >= 115",
    "Safari >= 16.4"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver",
      "msgpackr-extract"
    ],
    "overrides": {
      "effect": "^3.21.4",
      "postcss": "^8.5.15",
      "uuid": "^11.1.1"
    }
  }
}
