NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for server-side workspace creation, employee creation, and developer-level admin operations.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# One-time server bootstrap. Runtime authorization is then read only from developer_users.
DEVELOPER_BOOTSTRAP_EMAILS=developer@example.com

# Optional review login (local/staging only; disabled in production).
DEVELOPER_REVIEW_LOGIN_ENABLED=false
DEVELOPER_REVIEW_EMAIL=developer@example.com
DEVELOPER_REVIEW_PASSWORD=replace-with-a-strong-secret
DEVELOPER_REVIEW_NAME=Platform Developer

# UploadThing profile image uploads
UPLOADTHING_TOKEN=
